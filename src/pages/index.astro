---
import BaseLayout from '@layouts/BaseLayout.astro';
import ThemeToggle from '@components/ui/ThemeToggle.astro';
---

<BaseLayout title="Home">
  <!-- Header -->
  <header class="fixed top-0 w-full z-50 bg-bg/80 backdrop-blur-md border-b border-border">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex justify-between items-center">
      <span class="font-semibold text-sm tracking-tight">System Design Playbook</span>
      <ThemeToggle />
    </div>
  </header>

  <main class="pt-14">
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-layer-entry-light via-bg to-layer-data-light dark:from-layer-entry-dark/30 dark:via-bg dark:to-layer-data-dark/30 opacity-60"></div>
      <div class="relative max-w-4xl mx-auto px-4 sm:px-6 py-20 sm:py-32 text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-tight">
          System Design
          <span class="block text-layer-entry">Playbook</span>
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed">
          Aprenda a raciocinar, planejar e apresentar system design em entrevistas técnicas.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/00-introducao"
            class="inline-flex items-center justify-center px-8 py-3.5 rounded-lg bg-layer-entry text-white font-semibold hover:bg-layer-entry/90 transition-colors shadow-lg shadow-layer-entry/25"
          >
            Começar a ler
            <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="/quick-win"
            class="inline-flex items-center justify-center px-8 py-3.5 rounded-lg border border-border bg-bg hover:bg-bg-secondary font-semibold transition-colors"
          >
            Quick Win (5 min)
          </a>
        </div>
      </div>
    </section>

    <!-- 4-Layer Framework Visual -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
        <div class="rounded-xl border-2 border-layer-entry bg-layer-entry-light dark:bg-layer-entry-dark/30 p-4 sm:p-6 text-center">
          <div class="text-2xl sm:text-3xl font-bold text-layer-entry">1</div>
          <div class="mt-1 font-semibold text-sm sm:text-base text-layer-entry">Entry</div>
          <div class="mt-1 text-xs text-text-muted">API, Gateway, LB</div>
        </div>
        <div class="rounded-xl border-2 border-layer-service bg-layer-service-light dark:bg-layer-service-dark/30 p-4 sm:p-6 text-center">
          <div class="text-2xl sm:text-3xl font-bold text-layer-service">2</div>
          <div class="mt-1 font-semibold text-sm sm:text-base text-layer-service">Service</div>
          <div class="mt-1 text-xs text-text-muted">Business logic</div>
        </div>
        <div class="rounded-xl border-2 border-layer-data bg-layer-data-light dark:bg-layer-data-dark/30 p-4 sm:p-6 text-center">
          <div class="text-2xl sm:text-3xl font-bold text-layer-data">3</div>
          <div class="mt-1 font-semibold text-sm sm:text-base text-layer-data">Data</div>
          <div class="mt-1 text-xs text-text-muted">DB, Cache, Queue</div>
        </div>
        <div class="rounded-xl border-2 border-layer-cross bg-layer-cross-light dark:bg-layer-cross-dark/30 p-4 sm:p-6 text-center">
          <div class="text-2xl sm:text-3xl font-bold text-layer-cross">4</div>
          <div class="mt-1 font-semibold text-sm sm:text-base text-layer-cross">Cross</div>
          <div class="mt-1 text-xs text-text-muted">Monitoring, Auth</div>
        </div>
      </div>
    </section>

    <!-- Para quem e este guia -->
    <section class="bg-bg-secondary border-y border-border">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
        <h2 class="text-2xl sm:text-3xl font-bold text-center">Para quem é este guia</h2>
        <p class="mt-3 text-text-muted text-center max-w-xl mx-auto">
          Projetado para engenheiros que enfrentam entrevistas de system design em empresas de tecnologia.
        </p>
        <div class="mt-12 grid gap-6 sm:grid-cols-3">
          <!-- Senior Engineer -->
          <div class="rounded-xl border border-border bg-bg p-6 sm:p-8 hover:shadow-lg hover:border-layer-entry/40 transition-all">
            <div class="w-12 h-12 rounded-lg bg-layer-entry-light dark:bg-layer-entry-dark/40 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-layer-entry" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <h3 class="font-bold text-lg">Senior Engineer</h3>
            <p class="mt-2 text-sm text-text-muted leading-relaxed">
              Domine o framework de 4 camadas e aprenda a estruturar respostas claras e confiantes.
            </p>
          </div>
          <!-- Staff Engineer -->
          <div class="rounded-xl border border-border bg-bg p-6 sm:p-8 hover:shadow-lg hover:border-layer-service/40 transition-all">
            <div class="w-12 h-12 rounded-lg bg-layer-service-light dark:bg-layer-service-dark/40 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-layer-service" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
              </svg>
            </div>
            <h3 class="font-bold text-lg">Staff Engineer</h3>
            <p class="mt-2 text-sm text-text-muted leading-relaxed">
              Aprofunde trade-offs, escala horizontal, e como comunicar decisões arquiteturais complexas.
            </p>
          </div>
          <!-- Tech Lead -->
          <div class="rounded-xl border border-border bg-bg p-6 sm:p-8 hover:shadow-lg hover:border-layer-data/40 transition-all">
            <div class="w-12 h-12 rounded-lg bg-layer-data-light dark:bg-layer-data-dark/40 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-layer-data" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-bold text-lg">Tech Lead</h3>
            <p class="mt-2 text-sm text-text-muted leading-relaxed">
              Pratique exercícios guiados que simulam entrevistas reais em grandes empresas de tech.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- O que voce vai aprender -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-center">O que você vai aprender</h2>
      <p class="mt-3 text-text-muted text-center max-w-xl mx-auto">
        Três pilares que transformam candidatos em especialistas em system design.
      </p>
      <div class="mt-12 grid gap-8 sm:grid-cols-3">
        <!-- Raciocinio Estruturado -->
        <div class="text-center sm:text-left">
          <div class="inline-flex w-14 h-14 rounded-2xl bg-layer-entry/10 dark:bg-layer-entry/20 items-center justify-center mb-4">
            <span class="text-2xl font-bold text-layer-entry">01</span>
          </div>
          <h3 class="font-bold text-lg">Raciocínio Estruturado</h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">
            Um framework mental para decompor qualquer problema de system design em partes gerenciáveis, do escopo à validação.
          </p>
        </div>
        <!-- Metodologia Visual -->
        <div class="text-center sm:text-left">
          <div class="inline-flex w-14 h-14 rounded-2xl bg-layer-service/10 dark:bg-layer-service/20 items-center justify-center mb-4">
            <span class="text-2xl font-bold text-layer-service">02</span>
          </div>
          <h3 class="font-bold text-lg">Metodologia Visual</h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">
            Diagramas com 4 camadas (Entry, Service, Data, Cross) que o entrevistador consegue acompanhar em tempo real.
          </p>
        </div>
        <!-- Pratica com Exercicios -->
        <div class="text-center sm:text-left">
          <div class="inline-flex w-14 h-14 rounded-2xl bg-layer-data/10 dark:bg-layer-data/20 items-center justify-center mb-4">
            <span class="text-2xl font-bold text-layer-data">03</span>
          </div>
          <h3 class="font-bold text-lg">Prática com Exercícios</h3>
          <p class="mt-2 text-sm text-text-muted leading-relaxed">
            Exercícios guiados com cenários reais — URL Shortener, Chat, Feed — com timer e checklist de avaliação.
          </p>
        </div>
      </div>
    </section>

    <!-- Quick Win Banner -->
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-16">
      <a
        href="/quick-win"
        class="block rounded-2xl border border-layer-entry/30 bg-gradient-to-r from-layer-entry-light to-layer-service-light dark:from-layer-entry-dark/20 dark:to-layer-service-dark/20 p-6 sm:p-8 hover:shadow-lg transition-all group"
      >
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <div class="text-xs font-semibold uppercase tracking-wider text-layer-entry mb-1">Quick Win</div>
            <h3 class="font-bold text-lg sm:text-xl">Framework Mental em 5 Passos</h3>
            <p class="mt-1 text-sm text-text-muted">
              Abra 2 minutos antes da entrevista. Tudo que você precisa numa única página.
            </p>
          </div>
          <div class="shrink-0">
            <span class="inline-flex items-center gap-2 text-layer-entry font-semibold group-hover:gap-3 transition-all">
              Abrir
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </div>
        </div>
      </a>
    </section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-border bg-bg-secondary">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8 text-center text-sm text-text-muted">
      <p>&copy; 2026 System Design Playbook. Todos os direitos reservados.</p>
    </div>
  </footer>
</BaseLayout>
