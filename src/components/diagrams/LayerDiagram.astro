---
import { LAYER_COLORS, ARROW_COLORS } from '@utils/diagrams';
import type { LayerId } from '@utils/diagrams';

interface Props {
  layers: Array<{
    id: LayerId;
    label: string;
    boxes: Array<{ name: string; description?: string }>;
  }>;
  arrows?: Array<{
    from: string;
    to: string;
    type: 'sync' | 'async';
    label?: string;
  }>;
  showLegend?: boolean;
  highlightLayer?: string;
  compact?: boolean;
}

const { layers, arrows = [], showLegend = true, highlightLayer, compact = false } = Astro.props;

const bandHeight = compact ? 80 : 120;
const bandPadding = 16;
const boxWidth = compact ? 100 : 130;
const boxHeight = compact ? 36 : 48;
const boxGap = 16;
const labelWidth = 120;
const svgWidth = 800;
const svgHeight = layers.length * (bandHeight + 8) + (showLegend ? 60 : 16);
---

<div class="my-6 overflow-x-auto">
  <svg
    viewBox={`0 0 ${svgWidth} ${svgHeight}`}
    class="w-full max-w-3xl mx-auto"
    role="img"
    aria-label="Architecture layer diagram"
  >
    {layers.map((layer, layerIndex) => {
      const y = layerIndex * (bandHeight + 8) + 4;
      const colors = LAYER_COLORS[layer.id];
      const isHighlighted = !highlightLayer || highlightLayer === layer.id;
      const opacity = isHighlighted ? 1 : 0.35;

      return (
        <g opacity={opacity}>
          {/* Band background */}
          <rect
            x="0"
            y={y}
            width={svgWidth}
            height={bandHeight}
            rx="8"
            fill={colors.bgLight}
            stroke={colors.border}
            stroke-width="1.5"
          />

          {/* Layer label */}
          <text
            x={bandPadding}
            y={y + bandHeight / 2}
            dominant-baseline="middle"
            fill={colors.bg}
            font-size={compact ? '11' : '13'}
            font-weight="600"
          >
            {layer.label}
          </text>

          {/* Boxes within layer */}
          {layer.boxes.map((box, boxIndex) => {
            const bx = labelWidth + boxIndex * (boxWidth + boxGap);
            const by = y + (bandHeight - boxHeight) / 2;
            return (
              <g>
                <rect
                  x={bx}
                  y={by}
                  width={boxWidth}
                  height={boxHeight}
                  rx="6"
                  fill={colors.bg}
                  stroke={colors.border}
                  stroke-width="1"
                />
                <text
                  x={bx + boxWidth / 2}
                  y={by + (box.description ? boxHeight / 2 - 6 : boxHeight / 2)}
                  text-anchor="middle"
                  dominant-baseline="middle"
                  fill={colors.text}
                  font-size={compact ? '10' : '12'}
                  font-weight="500"
                >
                  {box.name}
                </text>
                {box.description && (
                  <text
                    x={bx + boxWidth / 2}
                    y={by + boxHeight / 2 + 10}
                    text-anchor="middle"
                    dominant-baseline="middle"
                    fill={colors.text}
                    font-size="9"
                    opacity="0.8"
                  >
                    {box.description}
                  </text>
                )}
              </g>
            );
          })}
        </g>
      );
    })}

    {/* Arrow placeholders */}
    {arrows.map((arrow) => {
      const isAsync = arrow.type === 'async';
      return (
        <line
          x1="200" y1="60" x2="200" y2="140"
          stroke={isAsync ? ARROW_COLORS.async : ARROW_COLORS.sync}
          stroke-width="2"
          stroke-dasharray={isAsync ? '8 4' : 'none'}
          marker-end="url(#arrowhead)"
        />
      );
    })}

    {/* Arrowhead marker */}
    <defs>
      <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
        <polygon points="0 0, 10 3.5, 0 7" fill="#1F2937" />
      </marker>
    </defs>

    {/* Legend */}
    {showLegend && (
      <g transform={`translate(${svgWidth - 260}, ${svgHeight - 50})`}>
        <rect x="0" y="0" width="250" height="44" rx="6" fill="white" stroke="#E5E7EB" stroke-width="1" opacity="0.9" />
        <text x="12" y="18" font-size="10" font-weight="600" fill="#374151">Legenda:</text>
        {/* Sync */}
        <line x1="12" y1="32" x2="40" y2="32" stroke={ARROW_COLORS.sync} stroke-width="2" />
        <text x="46" y="36" font-size="9" fill="#6B7280">Sincrono</text>
        {/* Async */}
        <line x1="120" y1="32" x2="148" y2="32" stroke={ARROW_COLORS.async} stroke-width="2" stroke-dasharray="8 4" />
        <text x="154" y="36" font-size="9" fill="#6B7280">Assincrono</text>
      </g>
    )}
  </svg>
</div>
