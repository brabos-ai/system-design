---
interface Props {
  showAsync?: boolean;
}

const { showAsync = true } = Astro.props;
---

<div class="inline-flex items-center gap-6 my-3 px-4 py-2 rounded-lg bg-bg-secondary border border-border text-xs">
  <!-- Sync -->
  <div class="flex items-center gap-2">
    <svg width="32" height="8" class="shrink-0">
      <line x1="0" y1="4" x2="28" y2="4" stroke="#1F2937" stroke-width="2" />
      <polygon points="28,0 32,4 28,8" fill="#1F2937" />
    </svg>
    <span class="text-text-muted">Sincrono (REST/gRPC)</span>
  </div>

  <!-- Async -->
  {showAsync && (
    <div class="flex items-center gap-2">
      <svg width="32" height="8" class="shrink-0">
        <line x1="0" y1="4" x2="28" y2="4" stroke="#F59E0B" stroke-width="2" stroke-dasharray="6 3" />
        <polygon points="28,0 32,4 28,8" fill="#F59E0B" />
      </svg>
      <span class="text-text-muted">Assincrono (Kafka/Filas)</span>
    </div>
  )}
</div>
