---
import { getCollection } from 'astro:content';
import { getChaptersByBlock } from '@utils/navigation';
import type { ChapterMeta } from '@utils/navigation';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

const allChapters = await getCollection('chapters');
const chapterMetas: ChapterMeta[] = allChapters
  .map((c) => ({
    id: c.id,
    title: c.data.title,
    subtitle: c.data.subtitle,
    chapter: c.data.chapter,
    block: c.data.block,
    estimatedTime: c.data.estimatedTime,
    difficulty: c.data.difficulty,
  }))
  .sort((a, b) => a.chapter - b.chapter);

const blocks = getChaptersByBlock(chapterMetas);
---

<nav class="flex flex-col h-full py-4" aria-label="Sidebar navigation">
  <!-- Logo / Title -->
  <div class="px-4 mb-4">
    <a href="/" class="text-lg font-bold text-text hover:text-layer-entry transition-colors">
      SD Playbook
    </a>
  </div>

  <!-- Quick Win link -->
  <a
    href="/quick-win"
    class="mx-3 mb-4 px-3 py-2 rounded-lg text-sm font-medium bg-layer-entry-light text-layer-entry dark:bg-layer-entry-dark dark:text-layer-entry-light hover:opacity-80 transition-opacity"
  >
    Quick Win
  </a>

  <!-- Chapter list grouped by block -->
  <div class="flex-1 overflow-y-auto px-2 space-y-2">
    {blocks.map((block) => (
      <details open class="group">
        <summary class="flex items-center gap-2 px-2 py-1.5 text-xs font-semibold uppercase tracking-wider text-text-muted cursor-pointer select-none hover:text-text transition-colors">
          <svg class="w-3 h-3 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
          {block.name}
        </summary>
        <ul class="mt-1 space-y-0.5">
          {block.chapters.map((chapter) => {
            const isActive = chapter.id === currentSlug;
            return (
              <li>
                <a
                  href={`/${chapter.id}`}
                  class:list={[
                    'block px-3 py-1.5 rounded-md text-sm transition-colors',
                    isActive
                      ? 'bg-layer-entry text-white font-medium'
                      : 'text-text-muted hover:text-text hover:bg-bg-secondary',
                  ]}
                >
                  <span class="text-xs opacity-60 mr-1">{chapter.chapter}.</span>
                  {chapter.title}
                </a>
              </li>
            );
          })}
        </ul>
      </details>
    ))}
  </div>
</nav>
