---
interface Props {
  author?: string;
  role?: string;
}

const { author, role } = Astro.props;
---

<figure class="my-8 relative">
  <div class="absolute -top-3 -left-1 text-5xl font-serif text-layer-entry/20 select-none leading-none">&ldquo;</div>
  <blockquote class="border-l-4 border-layer-entry pl-6 py-2">
    <div class="text-lg leading-relaxed italic text-text">
      <slot />
    </div>
  </blockquote>
  {(author || role) && (
    <figcaption class="mt-3 pl-6 text-sm text-text-muted">
      {author && <span class="font-medium text-text">{author}</span>}
      {author && role && <span> — </span>}
      {role && <span>{role}</span>}
    </figcaption>
  )}
</figure>
