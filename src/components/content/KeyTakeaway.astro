---
interface Props {
  title?: string;
}

const { title = 'Ponto-chave' } = Astro.props;
---

<div class="my-6 rounded-xl border border-amber-300 dark:border-amber-600 bg-amber-50 dark:bg-amber-900/20 p-5">
  <div class="flex items-center gap-2 mb-3">
    <!-- Lightbulb icon -->
    <svg class="w-5 h-5 text-amber-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
    </svg>
    <h4 class="font-semibold text-sm text-amber-800 dark:text-amber-300">{title}</h4>
  </div>
  <div class="text-sm leading-relaxed text-text">
    <slot />
  </div>
</div>
